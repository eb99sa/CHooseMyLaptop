# ---------------------------------------------------------------------------
# CHooseMyLaptop — Environment variables
# Copy this file to `.env.local` and fill in the values.
# ---------------------------------------------------------------------------

# --- Supabase (required for auth + database) -------------------------------
# Get these from: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Service role key — SERVER ONLY. Never expose to the browser.
# Used by admin dashboard, CSV export, and seeding.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- OpenRouter (AI provider) ----------------------------------------------
# Get a key at https://openrouter.ai/keys
# If left empty, the app falls back to a deterministic rule-based engine
# and clearly labels results as "estimated".
OPENROUTER_API_KEY=
# Any model slug available on OpenRouter. Pick one that returns valid JSON well.
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
# Optional attribution headers recommended by OpenRouter:
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=CHooseMyLaptop

# --- App configuration -----------------------------------------------------
# Public base URL, used to build magic-link redirect URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Comma-separated list of emails allowed into the /admin dashboard.
ADMIN_EMAILS=eb99sa@gmail.com

# --- Maps / Geocoding (optional, Phase 2) ----------------------------------
# Location search is a Phase 2 feature; the MVP uses a simple text field.
NEXT_PUBLIC_MAPBOX_TOKEN=
