# ---------------------------------------------------------------------------
# CHooseMyLaptop — Environment variables
# Copy this file to `.env.local` and fill in the values.
#
# The app is ANONYMOUS (no user accounts). All database access is server-side
# via the Supabase service-role key, so that key is REQUIRED.
# ---------------------------------------------------------------------------

# --- Supabase (required) ---------------------------------------------------
# Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Service role key — SERVER ONLY. Required: every DB call uses it. Never expose
# it to the browser. Project Settings > API > service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- OpenRouter (AI provider, optional) ------------------------------------
# If empty, the app falls back to a deterministic rule-based engine and clearly
# labels results as "estimated".
OPENROUTER_API_KEY=
# Any current OpenRouter model slug that supports JSON output. See
# https://openrouter.ai/models — verify the slug is live (deprecated slugs 404).
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=CHooseMyLaptop
# Multi-agent MECE spec engine (Phase 2). The 4 worker agents use OPENROUTER_MODEL;
# OPENROUTER_SYNTH_MODEL is the (optional) stronger model for the single synthesizer
# call. Leave empty to use OPENROUTER_MODEL; set a stronger slug to activate tiering.
OPENROUTER_SYNTH_MODEL=
# Kill-switch: "false" reverts to the legacy single-call spec path. Default: true.
OPENROUTER_MULTI_AGENT=true

# --- OpenAI embeddings (RAG, optional) -------------------------------------
# Used only for Phase 2 RAG retrieval (OpenRouter does not serve embeddings).
# If empty, retrieval is skipped and the recommendation runs exactly as before.
# After setting this, run supabase/rag.sql, then: npx tsx scripts/ingest-knowledge.mts
OPENAI_API_KEY=
# 1536-dim model to match the pgvector(1536) schema. Override only if you know
# your model's dimensions match the schema.
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Mapbox geocoding (optional) -------------------------------------------
# Server-side token used by /api/geocode for location search + reverse geocode.
# If empty, the location section degrades to a plain manual text field.
# Get a token at https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=

# --- Admin area (separate from the anonymous app) --------------------------
# The /admin dashboard is gated by a shared password + a signed cookie.
ADMIN_PASSWORD=change-me
# Secret used to sign the admin session cookie. Use a long random string.
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string

# --- App configuration -----------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
