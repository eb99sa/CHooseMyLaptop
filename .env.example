# ---------------------------------------------------------------------------
# CHooseMyLaptop — Environment variables
# Copy this file to `.env.local` and fill in the values.
#
# The app is ANONYMOUS (no user accounts). All database access is server-side
# via the Supabase service-role key, so that key is REQUIRED.
# ---------------------------------------------------------------------------

# --- Supabase (required) ---------------------------------------------------
# Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Service role key — SERVER ONLY. Required: every DB call uses it. Never expose
# it to the browser. Project Settings > API > service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- OpenRouter (AI provider, optional) ------------------------------------
# If empty, the app falls back to a deterministic rule-based engine and clearly
# labels results as "estimated".
OPENROUTER_API_KEY=
# Any current OpenRouter model slug that supports JSON output. See
# https://openrouter.ai/models — verify the slug is live (deprecated slugs 404).
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=CHooseMyLaptop

# --- Mapbox geocoding (optional) -------------------------------------------
# Server-side token used by /api/geocode for location search + reverse geocode.
# If empty, the location section degrades to a plain manual text field.
# Get a token at https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=

# --- Admin area (separate from the anonymous app) --------------------------
# The /admin dashboard is gated by a shared password + a signed cookie.
ADMIN_PASSWORD=change-me
# Secret used to sign the admin session cookie. Use a long random string.
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string

# --- App configuration -----------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
